{
  "name": "citation-generator",
  "version": "1.0.0",
  "description": "A citation generator",
  "main": "index.js",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/embed-csl.mjs",
    "build": "astro build",
    "preview": "npm run build && wrangler pages dev ./dist --compatibility-flags=\"nodejs_compat\"",
    "watch": "nodemon --ext tsx,astro,html,css --exec npm run build-tailwind",
    "build-tailwind": "tailwindcss -i ./src/styles/tailwind.css -o ./src/styles/tailwind-output.css",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@astrojs/cloudflare": "^9.0.2",
    "@astrojs/mdx": "^2.2.0",
    "@astrojs/react": "^3.0.10",
    "@astrojs/sitemap": "^3.1.1",
    "@heroicons/react": "^2.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@react-hook/media-query": "^1.1.1",
    "accept-language-parser": "^1.5.0",
    "astro": "^4.4.8",
    "astro-compress": "^2.2.11",
    "cheerio": "^1.0.0-rc.12",
    "citeproc": "^2.4.63",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "github-slugger": "^2.0.0",
    "lucide-react": "^0.471.1",
    "marked": "^18.0.4",
    "moment": "^2.30.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-tabs": "^6.0.2",
    "sharp": "^0.33.3",
    "tailwind-merge": "^2.5.2",
    "vaul": "^0.9.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.6.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "@testing-library/react": "^14.3.1",
    "jsdom": "^29.1.1",
    "tailwindcss": "^3.4.12",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3",
    "vitest": "1.3.0",
    "wrangler": "^4.95.0"
  }
}

---
import { BookOpenIcon } from "@heroicons/react/24/outline";
import Logo from "../../../public/images/logo.svg";
const site = Astro.site;

import { Bars3Icon } from "@heroicons/react/24/outline";
---

<!--
    Remove "Home" and make it "Citation Generator"
    Exisiting links to "Citation Generator" will be changed to "My Citations"
    We will only reference the Home as the "Citation Generator"
 -->
<header>
  <div class="logo">
    <a href={`${site}`} aria-label="MLA Generator">
      <!-- <p>MLA Generator</p> -->
      <img src={Logo.src} alt="MLA Generator" title="MLA Generator" width="213" height="35" />
    </a>
  </div>
  <nav aria-label="Primary" id="primary-nav">
    <ul id="menu-content">
      <li><a href={`${site}my-references/`}>My References</a></li>
      <li class="sub-menu-trigger">
        <button type="button" aria-haspopup="true" aria-expanded="false" aria-controls="guides-submenu">Citation Guides<svg class="nav-chevron" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5 10 12.5 15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></button>
        <ul class="sub-menu" id="guides-submenu" role="menu">
          <li role="none"><a role="menuitem" href={`${site}guides/`}>All Guides</a></li>
          <li role="none"><a role="menuitem" href={`${site}guides/research-and-works-cited/`}>Mastering Your Sources</a></li>
          <li role="none"><a role="menuitem" href={`${site}guides/mla/`}>MLA Format Guide</a></li>
          <li role="none"><a role="menuitem" href={`${site}guides/apa/`}>APA Format Guide</a></li>
          <li role="none"><a role="menuitem" href={`${site}guides/chicago/`}>Chicago Format Guide</a></li>
          <li role="none"><a role="menuitem" href={`${site}guides/harvard/`}>Harvard Format Guide</a></li>
        </ul>
      </li>
      <li class="sub-menu-trigger">
        <button type="button" aria-haspopup="true" aria-expanded="false" aria-controls="generators-submenu">Citation Generators<svg class="nav-chevron" width="14" height="14" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M5 7.5 10 12.5 15 7.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path></svg></button>
        <ul class="sub-menu" id="generators-submenu" role="menu">
          <li role="none"><a role="menuitem" href={`${site}apa-citation-generator/`}>APA Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}mla-citation-generator/`}>MLA Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}chicago-citation-generator/`}>Chicago Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}harvard-referencing-generator/`}>Harvard Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}ieee-citation-generator/`}>IEEE Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}ama-citation-generator/`}>AMA Generator</a></li>
          <li role="none"><a role="menuitem" href={`${site}vancouver-citation-generator/`}>Vancouver Generator</a></li>
        </ul>
      </li>
    </ul>
  </nav>
  <div id="obscure"></div>
  <button id="mobile-menu-toggle" type="button" aria-label="Toggle menu" aria-expanded="false" aria-controls="primary-nav">
    <div class="menu-bar" aria-hidden="true"></div>
    <div class="menu-bar" aria-hidden="true"></div>
    <div class="menu-bar" aria-hidden="true"></div>
  </button>
  <a class="button-primary" href="/">
    <BookOpenIcon className="button-icon" />
    <span>Create Citation</span>
  </a>
</header>


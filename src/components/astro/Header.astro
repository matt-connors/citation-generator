<style>
  .menu-bar {
    width: 26px;
    height: 1px;
    background-color: var(--color-text-dark);
    border-radius: 2px;
  }
  .menu-bar:nth-child(2) {
    width: 17px;
    align-self: end;
  }
  #mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 18px;
    cursor: pointer;
    padding: 5px;
    box-sizing: content-box;

    display: none;
  }
  #obscure {
    display: none;
  }
  @media (min-width: 1050px) {
    #menu-content {
      position: relative;
      height: 100%;
    }
    header li,
    header li a,
    header li span {
      height: 100%;
      display: flex;
      align-items: center;
    }
    .sub-menu-trigger {
      position: relative;
    }
    .sub-menu {
      display: none !important;
      flex-direction: column;
      align-items: flex-start !important;
      position: absolute;
      top: 90%;
      right: 0;
      background-color: var(--color-background-1);
      border-top: 1px solid var(--color-border);
      z-index: 9999;
      box-shadow:
        rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
        rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
        rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
        rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
        rgb(0 0 0 / 64%) 0 0 1px 0,
        rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
      border-radius: 0.5rem;
      gap: 0 !important;
      padding: 0.5rem 0;
    }
    .sub-menu li {
      width: 100%;
    }
    .sub-menu a {
      padding: 12px 1.2rem !important;
      /* border-radius: 0.5rem; */
      display: flex;
      width: 100%;
    }
    .sub-menu a:hover {
      background-color: var(--color-background-2);
    }
    .sub-menu-trigger:hover .sub-menu,
    .sub-menu-trigger:focus-within .sub-menu,
    .sub-menu:hover,
    .sub-menu.open {
      display: flex !important;
    }
  }
  @media (max-width: 1050px) {
    /* Take the nav landmark out of the header grid below 1050px so the
       hamburger doesn't get pushed onto a second row. The nav still exists
       in the DOM (its role is preserved by modern browsers/screen readers);
       its children become direct grid items, and the menu ul is itself
       display:none until header[open] adds the position-absolute dropdown. */
    #primary-nav {
      display: contents;
    }
    .sub-menu {
      flex-direction: column;
      align-items: flex-start !important;
    }
    .sub-menu-trigger button {
        display: none;
    }
    #menu-content {
      display: none;
      position: absolute;
      flex-direction: column;
      text-align: left;
      align-items: flex-start;
      top: 100%;
      padding: 2rem calc(1.5rem - 10px);
      background-color: var(--color-background-1);
      border-top: 1px solid var(--color-border);
      /* width: 100%; */
      left: 0;
      right: 0;
      box-sizing: border-box;
      z-index: 9999;
      box-shadow:
        rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
        rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
        rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
        rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
        rgb(0 0 0 / 64%) 0 0 1px 0,
        rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
    }
    #mobile-menu-toggle {
      display: flex;
    }
    header[open] #menu-content {
      display: flex;
    }
    header[open] #obscure {
      display: flex;
      position: absolute;
      top: 100%;
      height: calc(100vh - 100%);
      width: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      z-index: 0;
    }
  }
  @media (max-width: 650px) {
    /* Keep the default 3-column grid (1fr auto auto) — overriding to 2 columns
       caused the hamburger button to wrap to a new row at narrow widths even
       with #primary-nav using display:contents. The button-primary is still
       hidden so the third column ends up zero-width auto. */
    header .button-primary {
      display: none;
    }
  }
  header {
    display: grid;
    align-items: center;
    grid-template-columns: 1fr auto auto;
    height: 70px;
    position: sticky;
    top: 0;
    box-shadow:
      rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
      rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
      rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
      rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
      rgb(0 0 0 / 64%) 0 0 1px 0,
      rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
    /* The sticky header must paint above every in-page popover — the
       citation-style dropdown (z-index 999) and the More source-type menu.
       The header's own submenus stack inside this context, so they are
       unaffected. */
    z-index: 1000;
    background-color: var(--color-background-1);
    padding: 0 var(--page-inline-padding);
    padding: 0 1.5rem;
    gap: 30px;
  }
  header ul {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  header li a,
  header li span {
    padding: 10px;
    cursor: pointer;
  }
  .logo {
    display: flex;
    height: 28px;
  }
  .logo img {
    height: 100%;
    width: auto;
    image-rendering: -webkit-optimize-contrast;
  }
  .sub-menu-trigger button {
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    padding: 10px;
  }
  .sub-menu-trigger button:focus-visible {
    outline: 2px solid var(--color-text-dark);
    outline-offset: 2px;
    border-radius: 4px;
  }
  /* Dropdown indicator: points down when closed, rotates up when the menu is
     open via hover (desktop), keyboard focus, or aria-expanded (click). */
  .nav-chevron {
    display: inline-block;
    vertical-align: middle;
    margin-left: 0.25rem;
    color: var(--color-text-light);
    transition: transform 0.2s ease;
  }
  .sub-menu-trigger:hover .nav-chevron,
  .sub-menu-trigger:focus-within .nav-chevron,
  .sub-menu-trigger button[aria-expanded="true"] .nav-chevron {
    transform: rotate(180deg);
    color: var(--color-text-dark);
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-chevron {
      transition: none;
    }
  }
</style>

<script>
  const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
  const header = document.querySelector("header");
  const obscure = document.getElementById("obscure");

  mobileMenuToggle!.addEventListener("click", () => {
    const isOpen = header!.toggleAttribute("open");
    mobileMenuToggle!.setAttribute("aria-expanded", String(isOpen));
  });

  obscure!.addEventListener("click", (e) => {
    header!.removeAttribute("open");
    mobileMenuToggle!.setAttribute("aria-expanded", "false");
  });

  // Sub-menu triggers: toggle aria-expanded on each button so screen readers
  // know the popover state. Visual show/hide remains driven by CSS. Each
  // trigger controls the sub-menu named by its aria-controls attribute.
  const subMenuTriggerBtns = document.querySelectorAll('.sub-menu-trigger button');
  const subMenuFor = (btn: Element) => document.getElementById(btn.getAttribute('aria-controls') ?? '');
  subMenuTriggerBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      subMenuFor(btn)?.classList.toggle('open');
    });
  });
  document.addEventListener('click', (e) => {
    subMenuTriggerBtns.forEach((btn) => {
      const subMenu = subMenuFor(btn);
      if (!btn.contains(e.target as Node) && !subMenu?.contains(e.target as Node)) {
        btn.setAttribute('aria-expanded', 'false');
        subMenu?.classList.remove('open');
      }
    });
  });
</script>

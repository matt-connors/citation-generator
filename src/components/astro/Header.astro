<style>
  .menu-bar {
    width: 26px;
    height: 1px;
    background-color: var(--color-text-dark);
    border-radius: 2px;
  }
  .menu-bar:nth-child(2) {
    width: 17px;
    align-self: end;
  }
  #mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 18px;
    cursor: pointer;
    padding: 5px;
    box-sizing: content-box;

    display: none;
  }
  #obscure {
    display: none;
  }
  @media (min-width: 1050px) {
    #menu-content {
      position: relative;
      height: 100%;
    }
    header li,
    header li a,
    header li span {
      height: 100%;
      display: flex;
      align-items: center;
    }
    .sub-menu {
      display: none !important;
      flex-direction: column;
      align-items: flex-start !important;
      position: absolute;
      top: 90%;
      right: 0;
      background-color: var(--color-background-1);
      border-top: 1px solid var(--color-border);
      z-index: 9999;
      box-shadow:
        rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
        rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
        rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
        rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
        rgb(0 0 0 / 64%) 0 0 1px 0,
        rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
      border-radius: 0.5rem;
      gap: 0 !important;
      padding: 0.5rem 0;
    }
    .sub-menu li {
      width: 100%;
    }
    .sub-menu a {
      padding: 12px 1.2rem !important;
      /* border-radius: 0.5rem; */
      display: flex;
      width: 100%;
    }
    .sub-menu a:hover {
      background-color: var(--color-background-2);
    }
    .sub-menu-trigger:hover + .sub-menu,
    .sub-menu-trigger:focus-within + .sub-menu,
    .sub-menu:hover,
    .sub-menu.open {
      display: flex !important;
    }
  }
  @media (max-width: 1050px) {
    .sub-menu {
      flex-direction: column;
      align-items: flex-start !important;
    }
    .sub-menu-trigger {
        display: none;
    }
    #menu-content {
      display: none;
      position: absolute;
      flex-direction: column;
      text-align: left;
      align-items: flex-start;
      top: 100%;
      padding: 2rem calc(1.5rem - 10px);
      background-color: var(--color-background-1);
      border-top: 1px solid var(--color-border);
      /* width: 100%; */
      left: 0;
      right: 0;
      box-sizing: border-box;
      z-index: 9999;
      box-shadow:
        rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
        rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
        rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
        rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
        rgb(0 0 0 / 64%) 0 0 1px 0,
        rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
    }
    #mobile-menu-toggle {
      display: flex;
    }
    header[open] #menu-content {
      display: flex;
    }
    header[open] #obscure {
      display: flex;
      position: absolute;
      top: 100%;
      height: calc(100vh - 100%);
      width: 100%;
      background-color: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(5px);
      -webkit-backdrop-filter: blur(5px);
      z-index: 0;
    }
  }
  @media (max-width: 650px) {
    header {
      grid-template-columns: 1fr auto !important;
    }
    header .button-primary {
      display: none;
    }
  }
  header {
    display: grid;
    align-items: center;
    grid-template-columns: 1fr auto auto;
    height: 70px;
    position: sticky;
    top: 0;
    box-shadow:
      rgba(0, 0, 0, 0.04) 0 24px 48px -4px,
      rgba(0, 0, 0, 0.02) 0 12px 24px -4px,
      rgba(0, 0, 0, 0.02) 0 8px 16px -4px,
      rgba(0, 0, 0, 0.02) 0 4px 8px -2px,
      rgb(0 0 0 / 64%) 0 0 1px 0,
      rgba(0, 0, 0, 0.02) 0 48px 96px -4px;
    z-index: 9;
    background-color: var(--color-background-1);
    padding: 0 var(--page-inline-padding);
    padding: 0 1.5rem;
    gap: 30px;
  }
  header ul {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  header li a,
  header li span {
    padding: 10px;
    cursor: pointer;
  }
  .logo {
    display: flex;
    height: 28px;
  }
  .logo img {
    height: 100%;
    width: auto;
    image-rendering: -webkit-optimize-contrast;
  }
  .sub-menu-trigger button {
    background: none;
    border: none;
    color: inherit;
    font: inherit;
    cursor: pointer;
    padding: 10px;
  }
  .sub-menu-trigger button:focus-visible {
    outline: 2px solid var(--color-text-dark);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>

<script>
  const mobileMenuToggle = document.getElementById("mobile-menu-toggle");
  const header = document.querySelector("header");
  const obscure = document.getElementById("obscure");

  mobileMenuToggle!.addEventListener("click", () => {
    header!.toggleAttribute("open");
  });

  obscure!.addEventListener("click", (e) => {
    header!.removeAttribute("open");
  });

  // Sub-menu trigger: toggle aria-expanded on the button so screen readers
  // know the popover state. Visual show/hide remains driven by CSS.
  const subMenuTriggerBtn = document.querySelector('.sub-menu-trigger button');
  const subMenu = document.getElementById('guides-submenu');
  subMenuTriggerBtn?.addEventListener('click', () => {
    const expanded = subMenuTriggerBtn.getAttribute('aria-expanded') === 'true';
    subMenuTriggerBtn.setAttribute('aria-expanded', String(!expanded));
    subMenu?.classList.toggle('open');
  });
  document.addEventListener('click', (e) => {
    if (!subMenuTriggerBtn?.contains(e.target as Node) && !subMenu?.contains(e.target as Node)) {
      subMenuTriggerBtn?.setAttribute('aria-expanded', 'false');
      subMenu?.classList.remove('open');
    }
  });
</script>

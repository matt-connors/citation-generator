---
import Layout from "../layouts/page.astro";
import CitationSearch from "../components/react/CitationSearch";
import {
    buildSoftwareApplication,
    buildFaqPage,
    buildBreadcrumbList,
} from "../lib/schema-org";

export const prerender = true;

const title = "Chicago Citation Generator — Free Chicago 18 Tool";
const description =
    "Free Chicago citation generator following the Chicago Manual of Style 18th edition. Build author–date references from a URL, DOI, or ISBN in seconds.";

const faqs = [
    {
        question: "Which Chicago system does this generator produce?",
        answer: "<p>This tool generates Chicago 18 <strong>author–date</strong> citations — parenthetical <code>(Author Year)</code> citations in the text and a <em>References</em> list at the end. If your assignment requires the <strong>notes–bibliography</strong> system (common in history and the humanities), use the generated reference list as a starting point and adapt the footnotes by hand using our <a href='/guides/chicago-notes-vs-author-date'>notes vs. author–date guide</a>.</p>",
    },
    {
        question: "Does Chicago put a comma between the author and the year?",
        answer: "<p>No. Chicago author–date drops the comma: write <code>(Chen 2021)</code>, not <code>(Chen, 2021)</code>. A page number for a direct quote follows after a comma with no <code>p.</code> abbreviation — <code>(Chen 2021, 47)</code>. The comma between author and year is APA's convention, not Chicago's.</p>",
    },
    {
        question: "Does Chicago use title case or sentence case?",
        answer: "<p>Chicago uses <strong>title case</strong> for every title — books, journals, articles, and chapters alike. (The 18th edition renamed the old \"headline-style\" to \"title case.\") Capitalize the first and last words and all major words; lowercase articles, coordinating conjunctions, and prepositions of four or fewer letters. The generator applies this automatically.</p>",
    },
    {
        question: "Do Chicago references keep the https:// in a URL?",
        answer: "<p>Yes. Unlike MLA, which strips the protocol, Chicago retains the <code>https://</code> prefix on plain URLs and formats DOIs as full URLs (<code>https://doi.org/…</code>) at the end of the entry. An access date is optional for stable sources and recommended for pages that may change.</p>",
    },
    {
        question: "Is this Chicago citation generator free?",
        answer: "<p>Yes — it is completely free, with no account required. Paste a URL, DOI, or ISBN, pick Chicago, and copy the formatted citation. Need a different style? Use the full <a href='/'>citation generator</a> on the homepage for APA, MLA, Harvard, Vancouver, IEEE, and AMA.</p>",
    },
];

const siteBase = new URL("/", Astro.site).toString();
const pageUrl = new URL("/chicago-citation-generator/", Astro.site).toString();

const extraSchemas = [
    buildSoftwareApplication(),
    buildFaqPage(faqs),
    buildBreadcrumbList([
        { name: "Home", url: siteBase },
        { name: "Chicago Citation Generator", url: pageUrl },
    ]),
];
---

<Layout title={title} description={description} extraSchemas={extraSchemas}>
    <section id="tool">
        <div id="text-container">
            <h1 class="heading-1">Chicago Citation Generator</h1>
            <p class="subtitle">
                Create accurate Chicago citations in seconds. This free tool
                builds Chicago Manual of Style 18th edition author–date
                references from a URL, DOI, or ISBN — then formats the
                punctuation, italics, and hanging indent for you.
            </p>
        </div>
        <CitationSearch includeDropdown includeManualCite defaultStyle="chicago-18" client:load />
    </section>

    <article class="cite-guide">
        <h2>How to cite in Chicago</h2>
        <p>
            Chicago is the style of historians, art historians, and a long list
            of humanities and social-science fields. What makes it unusual is
            that the <em>Chicago Manual of Style</em> (18th edition, 2024)
            documents two parallel systems. <strong>Author–date</strong> uses
            <code>(Author Year)</code> citations in the text with a
            <em>References</em> list at the end — this is what the generator above
            produces. <strong>Notes–bibliography</strong> uses superscript
            footnotes with a <em>Bibliography</em> at the end and is the default
            in history and most humanities.
        </p>
        <p>
            For an author–date in-text citation, give the surname and year with
            no comma between them — <code>(Lin and Patel 2022)</code> — and add a
            page number after a comma for direct quotes:
            <code>(Chen 2021, 47)</code>. Three or more authors collapse to
            <code>(Goldstein et al. 2024)</code> from the first citation. In the
            reference list, invert the first author, place the year right after
            the author block, use title case for every title, and apply a
            half-inch hanging indent.
        </p>
        <p>
            This page covers the essentials. For worked examples of every source
            type, the notes–bibliography rules, and what changed in the 18th
            edition, read the full guides:
        </p>
        <ul>
            <li>
                <a href="/guides/chicago">Complete Chicago citation guide</a> —
                in-text citations, reference list, and source-type examples.
            </li>
            <li>
                <a href="/guides/chicago-notes-vs-author-date"
                    >Chicago notes–bibliography vs. author–date</a
                > — which system to use and how they differ.
            </li>
            <li>
                <a href="/guides/how-to-cite-a-book">How to cite a book</a> and
                <a href="/guides/how-to-cite-a-website">how to cite a website</a>
                in Chicago and the other major styles.
            </li>
            <li>
                <a href="/guides/in-text-citations">In-text citations explained</a>
                — parenthetical and narrative forms across styles.
            </li>
        </ul>
        <p>
            Need a style other than Chicago? The
            <a href="/">free citation generator</a> on the homepage supports APA,
            MLA, Chicago, Harvard, Vancouver, IEEE, and AMA.
        </p>
    </article>

    <section class="faq-section">
        <h2>Chicago citation FAQs</h2>
        <div class="faq-container">
            {
                faqs.map((faq, i) => (
                    <details class="faq" open={i === 0}>
                        <summary>{faq.question}</summary>
                        <div set:html={faq.answer} class="faq-content" />
                    </details>
                ))
            }
        </div>
    </section>
</Layout>

<style is:global>
    /* Tool hero (mirrors index.astro) */
    #tool {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 0 var(--page-inline-padding);
    }
    #text-container {
        text-align: center;
        margin: 4rem 0;
    }
    #text-container .heading-1 {
        margin-bottom: 1rem;
    }
    #text-container .subtitle {
        max-width: 52ch;
        margin: 0 auto;
        color: var(--color-text-light);
    }

    /* How-to-cite section */
    .cite-guide {
        max-width: 950px;
        margin: 0 auto;
        padding: min(calc(8vw + 2rem), 5rem) 1.5rem 3rem;
        color: var(--color-text-light);
        line-height: 1.6;
        overflow-wrap: break-word;
    }
    .cite-guide h2 {
        font-size: 1.6rem;
        margin-bottom: 1rem;
        color: var(--color-text-dark);
    }
    .cite-guide p,
    .cite-guide ul {
        margin-bottom: 1rem;
    }
    .cite-guide ul {
        padding-left: 1.5rem;
        list-style: disc;
    }
    .cite-guide li {
        margin-bottom: 0.5rem;
    }
    .cite-guide a {
        color: var(--color-text-dark);
        text-decoration: underline;
    }
    .cite-guide code {
        font-size: 0.95em;
    }

    /* FAQ (mirrors index.astro) */
    .faq-section {
        padding: 3rem 0 5rem;
    }
    .faq-section > h2 {
        text-align: center;
        font-size: 1.8rem;
        margin-bottom: 2rem;
        color: var(--color-text-dark);
    }
    .faq-container {
        display: grid;
        gap: 1rem;
        max-width: calc(950px + var(--page-inline-padding) * 2);
        padding: 0 var(--page-inline-padding);
        margin: auto;
    }
    .faq {
        padding: 1.3rem;
        border-radius: 1rem;
        background-color: var(--color-background-3);
        text-align: left;
    }
    .faq summary {
        font-size: 1.3rem;
        cursor: pointer;
        user-select: none;
        line-height: 1.2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .faq[open] summary {
        margin-bottom: 1rem;
    }
    .faq[open] summary::after {
        content: url("/icons/close.svg");
        transform: translate(0, 2px);
    }
    .faq summary::after {
        content: url("/icons/open.svg");
        display: flex;
        align-items: center;
        transform: translate(-1px, 2px);
        width: 20px;
        height: 20px;
    }
    .faq-content {
        color: var(--color-text-light);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .faq-content a {
        text-decoration: underline;
        color: var(--color-text-dark);
    }
    @media (max-width: 700px) {
        .faq summary {
            font-size: 1.2rem;
        }
    }
</style>

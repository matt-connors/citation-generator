---
import Layout from "../layouts/page.astro";
import CitationSearch from "../components/react/CitationSearch";
import PageSegment from "../components/astro/PageSegment.astro";

import advantages from "../content/index/advantages";
import faqs from "../content/index/faqs";

import {
    ArrowUpRightIcon,
    DocumentTextIcon,
} from "@heroicons/react/24/outline";

import { buildSoftwareApplication, buildFaqPage } from "../lib/schema-org";

export const prerender = true;

const title = "Free Citation Generator for APA, MLA, Chicago & More";
const description =
    "Create APA, MLA, Chicago, Harvard, Vancouver, IEEE, and AMA citations from a URL, DOI, or ISBN. Free, editable, and built for student papers.";

const extraSchemas = [buildSoftwareApplication(), buildFaqPage(faqs)];
---

<Layout title={title} description={description} extraSchemas={extraSchemas}>
    <section id="tool">
        <div id="text-container">
            <h1 class="heading-1">Free Citation <br />Generator</h1>
            <p class="subtitle">
                Accurate APA, MLA, Chicago, Harvard, Vancouver, IEEE, and AMA
                citations — trusted by students worldwide.
            </p>
        </div>
        <CitationSearch includeDropdown includeManualCite client:load />
    </section>
    <PageSegment title="MLA Citation Generator Features" background>
        <div class="advantage-card-container">
            {
                advantages.map((advantage) => (
                    <div class="advantage-card">
                        <div class="advantage-card-top">
                            {<advantage.icon className="advantage-card-icon" />}
                            <h3>{advantage.heading}</h3>
                        </div>
                        <p>{advantage.text}</p>
                    </div>
                ))
            }
        </div>
    </PageSegment>
    <article id="guide-snippet">
        <h2 class="heading-2">How MLA Generator Builds Your Citations</h2>
        <div id="guide-snippet-columns">
            <!-- <nav id="guide-snippet-nav">
                <p class="heading-3">Guide</p>
                <ul>
                    <li>
                        <a href="#what-is-a-works-cited-page"> Introduction</a>
                    </li>
                    <li>
                        <a href="#how-to-create-a-works-cited-page">
                            Finding sources
                        </a>
                    </li>
                    <li>
                        <a href="#a-quick-guide-to-working-with-sources">
                            Evaluating sources
                        </a>
                    </li>
                    <li>
                        <a href="#how-to-create-a-works-cited-page">
                            Integrating sources
                        </a>
                    </li>
                    <li>
                        <a href="#how-to-create-a-works-cited-page">
                            Citing sources
                        </a>
                    </li>
                    <li>
                        <a href="#how-to-create-a-works-cited-page">
                            Tools and resources
                        </a>
                    </li>
                </ul>
            </nav> -->
            <div id="guide-snippet-content">
                <p>
                    Citation work usually falls apart in small places: a missing
                    publication date, a title copied in the wrong capitalization,
                    a URL saved without the article author, or a source entered
                    in APA when the assignment asked for MLA. MLA Generator is
                    built around those details. Paste a URL or ISBN, pick
                    the style your paper requires, then review the editable
                    fields before you copy the finished reference.
                </p>

                <h3 class="heading-3">Evidence first, then formatting</h3>

                <p>
                    Most citation mistakes start with bad data, not bad
                    punctuation. Paste a link and the generator fetches the page
                    and reads the metadata publishers embed for exactly this
                    purpose — author, title, site name, and date. An ISBN is
                    looked up in book databases instead. Only then does a
                    structured citation engine apply the punctuation, italics, and
                    author order your style requires. It never invents a field it
                    cannot find: missing details are left blank for you to fill,
                    and every field stays editable.
                </p>

                <h3 class="heading-3">What you can cite — and in which style</h3>

                <p>
                    The generator cites any website or book — paste a URL or an
                    ISBN — and formats it in all seven major styles, each matched
                    to its current edition. Which one you need usually comes from
                    the assignment sheet or the discipline:
                </p>

                <ul>
                    <li>
                        <a href="/guides/apa/">APA 7</a>: psychology, education,
                        and the social sciences.
                    </li>
                    <li>
                        <a href="/guides/mla/">MLA 9</a>: literature, languages,
                        and the humanities.
                    </li>
                    <li>
                        <a href="/guides/chicago/">Chicago 18</a>: history and the
                        arts (author–date).
                    </li>
                    <li>
                        <a href="/guides/harvard/">Harvard</a> (Cite Them Right):
                        used across many UK universities.
                    </li>
                    <li>
                        <a href="/guides/vancouver/">Vancouver</a> and
                        <a href="/guides/ieee/">IEEE</a>: numbered styles for
                        medicine, science, and engineering.
                    </li>
                    <li>
                        <a href="/guides/ama/">AMA 11</a>: medicine and the health
                        sciences.
                    </li>
                </ul>

                <p>
                    Styles differ in in-text form, title capitalization, author
                    order, and how dates and page ranges are written. Each
                    edition-accurate <a href="/guides/">citation style guide</a>
                    works through the rules with examples for every source type.
                </p>

                <h3 class="heading-3">Create a citation in four steps</h3>

                <ol>
                    <li>
                        Paste a website URL or a book's ISBN — or switch to
                        manual entry for anything else.
                    </li>
                    <li>Choose your citation style from the dropdown.</li>
                    <li>
                        Generate: the tool retrieves what it can and formats both
                        the reference and the in-text citation.
                    </li>
                    <li>
                        Review the fields — confirm the author and date, correct
                        anything the page mislabeled — then copy it into your
                        paper.
                    </li>
                </ol>

                <p>
                    Every citation is saved to <a href="/my-references/">My
                    References</a> in your browser, so you can build a works-cited
                    list as you research instead of reconstructing it the night
                    before the paper is due. No account, no sign-up.
                </p>

                <h3 class="heading-3">What still needs your judgment</h3>

                <p>
                    The generator handles the mechanics; the academic judgment
                    stays yours. Confirm the source is one worth citing, check the
                    auto-filled author and date against the page itself — web
                    pages mislabel them most often — and make sure the style
                    matches the one your assignment asks for. Get those right and
                    the formatting takes care of itself.
                </p>
            </div>
        </div>
    </article>
    <PageSegment title="MLA Generator FAQs" background>
        <div class="faq-container">
            {
                faqs.map((faq, i) => {
                    const open = i === 0;
                    return (
                        <details class="faq" open={open}>
                            <summary>{faq.question}</summary>
                            <div set:html={faq.answer} class="faq-content" />
                        </details>
                    );
                })
            }
            <a href="/my-references/" class="button-primary">
                <span>View My References</span>
                <ArrowUpRightIcon className="button-icon" />
            </a>
        </div>
    </PageSegment>
</Layout>

<style is:global>
    /* Guide */
    #guide-snippet {
        /* max-width: 1450px; */
        margin: auto;
        padding: min(calc(15vw + 2rem), 9rem) var(--page-inline-padding)
            min(5vw, 3rem);
        box-sizing: border-box;
    }
    #guide-snippet-columns {
        display: grid;
        grid-template-columns: auto 1fr;
        /* gap: 3rem clamp(3rem, 6vw, 6rem); */
        margin: auto;
        max-width: 950px;
    }
    @media (max-width: 1100px) {
        #guide-snippet-columns {
            grid-template-columns: 1fr;
        }
        #guide-snippet-nav {
            position: static !important;
            /* background-color: var(--color-background-2);
            padding: 1.5rem 2rem;
            border-radius: 24px; */
            /* width: fit-content; */

            border-top: 1px solid var(--color-border);
            padding-top: min(3rem, 13vw);
        }
        #guide-snippet-nav ul {
            width: fit-content;
        }
    }
    #guide-snippet .heading-2 {
        text-align: center;
        max-width: 20ch;
        margin: 0 auto min(3.5rem, 13vw);
        color: var(--color-text-light);
    }
    #guide-snippet-content {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    cite {
        font-style: normal;
    }
    #guide-snippet-content ul {
        list-style: circle;
        padding-left: 1.5rem;
    }
    #guide-snippet-content ol {
        list-style: auto;
        padding-left: 1.5rem;
    }
    #guide-snippet-content li {
        margin-bottom: 0.3rem;
        color: var(--color-text-light);
    }
    /* #guide-snippet-content .heading-2 {
        margin-bottom: 1rem;
        max-width: 23ch;
    } */
    #guide-snippet-content p + h3 {
        margin-top: 1.1rem;
    }
    #guide-snippet-content .button-primary {
        margin-top: 1rem;
    }
    #guide-snippet-content p {
        line-height: 1.4;
        color: var(--color-text-light);
    }
    #guide-snippet-content a {
        text-decoration: underline;
    }
    #guide-snippet-nav {
        position: sticky;
        top: 6rem;
        height: min-content;
    }
    #guide-snippet-nav ul {
        border-left: 1px solid var(--color-border);
    }
    #guide-snippet-nav a {
        padding: 4px 22px;
        display: block;
        color: var(--color-text-light);
    }
    #guide-snippet-nav a:hover {
        color: var(--color-text-dark);
        background-color: var(--color-background-2);
        border-radius: 8px;
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }
    #guide-snippet-nav .heading-3 {
        margin-bottom: 1rem;
    }
    #guide-snippet h3 {
        font-size: 1.3rem;
    }
    /* FAQ */
    .faq-container {
        display: grid;
        gap: 1rem;
        max-width: calc(950px + var(--page-inline-padding) * 2);
        padding: 0 var(--page-inline-padding);
        margin: auto;
    }
    .faq {
        padding: 1.3rem;
        border-radius: 1rem;
        background-color: var(--color-background-3);
        text-align: left;
    }
    .faq summary {
        font-size: 1.3rem;
        cursor: pointer;
        user-select: none;
        line-height: 1.2;

        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .faq[open] summary {
        margin-bottom: 1rem;
    }
    .faq[open] summary::after {
        content: url("/icons/close.svg");
        transform: translate(0, 2px);
    }
    .faq summary::after {
        content: url("/icons/open.svg");
        display: flex;
        align-items: center;
        transform: translate(-1px, 2px);

        width: 20px;
        height: 20px;
    }
    .faq-content ul {
        list-style-type: circle;
    }
    .faq-content a {
        text-decoration: underline;
        color: var(--color-text-dark);
    }
    .faq-content {
        color: var(--color-text-light);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .faq-container .button-primary {
        margin: 1rem auto 0 !important;
        gap: 10px;
    }
    .faq-container .button-icon {
        width: 17px;
    }
    @media (max-width: 700px) {
        .faq summary {
            font-size: 1.2rem;
        }
    }
    /* Tool */
    #tool {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 0 var(--page-inline-padding);
    }
    #text-container {
        text-align: center;
        margin: 4rem 0;
        /* margin: 5rem 0 3rem; */
    }
    #text-container .heading-1 {
        margin-bottom: 1rem;
    }
    #text-container .subtitle {
        max-width: 44ch;
        color: var(--color-text-light);
    }
    /* Features */
    .features {
        margin-top: 6rem;
    }
    /* #features .heading-2 a:hover {
text-decoration: underline;
text-decoration-thickness: 2px;
} */
    .advantage-card-container {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 380px), 1fr));
        gap: 2rem 1.6rem;
        /* gap: 1rem; */
        padding: 0 var(--page-inline-padding);
    }
    .advantage-card {
        padding: 18px var(--page-inline-padding);
        padding: 1.3rem 1.7rem;
        padding: 1.1rem;
        border-radius: 14px;
        border-radius: 28px;
        background-color: var(--color-background-2);
        background-color: var(--color-background-3);
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 7px;
    }
    .advantage-card > p {
        /* max-width: 26ch; */
        display: block;
        color: var(--color-text-light);
    }

    .advantage-card-top {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: calc(1rem - 7px);
    }
    @media (max-width: 760px) {
        .advantage-card-container {
            gap: 1.1rem;
        }
    }
    @media (max-width: 475px) {
        .advantage-card-top {
            flex-direction: column;
            align-items: flex-start;
        }
    }
    .advantage-card-top h3 {
        font-size: 1.3rem;
    }

    .advantage-card-icon {
        stroke-width: 1px;
        height: 36px;
        width: 44px;
        height: 44px;
        background-color: var(--color-brand);
        padding: 5px;
        box-sizing: border-box;
        border-radius: 14px;
        /* width: min-content; */
    }
</style>

---
import Layout from "../../layouts/page.astro";
import Breadcrumbs from "../../components/astro/Breadcrumbs.astro";
import GuideCardGrid from "../../components/astro/GuideCardGrid.astro";
import { buildBreadcrumbList, buildItemList } from "../../lib/schema-org";
import { GUIDE_CATEGORIES, categoryPath } from "../../lib/guide-categories";
import { getCollection } from "astro:content";
import { filterPublishedGuides } from "../../lib/publication";

const title = "Citation Guides — APA, MLA, Chicago, Harvard, Vancouver, IEEE, AMA";
const description =
    "In-depth citation guides for APA, MLA, Chicago, Harvard, Vancouver, IEEE, and AMA — plus how-to guides for citing websites, books, journal articles, and more.";

export const prerender = true;

const site = Astro.site!.toString().replace(/\/$/, '');
const breadcrumbSchema = buildBreadcrumbList([
    { name: 'Home', url: new URL('/', Astro.site).href },
    { name: 'Guides', url: new URL('/guides/', Astro.site).href },
]);

const all = filterPublishedGuides(await getCollection("guides"));
const sortByTitle = (a: typeof all[number], b: typeof all[number]) =>
    a.data.title.localeCompare(b.data.title);

const grouped = GUIDE_CATEGORIES.map((cat) => ({
    ...cat,
    items: all.filter((g) => g.data.category === cat.key).sort(sortByTitle),
}));

const itemListSchema = buildItemList(
    all.sort(sortByTitle).map((g) => ({
        name: g.data.title,
        description: g.data.description,
        url: `${site}/guides/${g.slug}/`,
    })),
    'Citation Guides',
    `${site}/guides/`,
);
---

<Layout title={title} description={description} extraSchemas={[breadcrumbSchema, itemListSchema]}>
    <article class="guides-hub">
        <Breadcrumbs items={[{ name: 'Home', href: '/' }, { name: 'Guides', href: '/guides/', current: true }]} />
        <header>
            <h1>Citation Guides</h1>
            <p class="lede">
                Authoritative guides covering every supported style — written
                and reviewed by the MLA Generator Editorial Team against the
                current editions of their respective style manuals. Or jump
                straight to the <a href="/">citation generator</a>.
            </p>
        </header>

        {grouped.map((group) => group.items.length > 0 && (
            <section aria-labelledby={`cat-${group.key}`}>
                <h2 id={`cat-${group.key}`}>
                    <a href={categoryPath(group.key)}>{group.label}</a>
                </h2>
                <p class="cat-blurb">{group.blurb}</p>
                <GuideCardGrid items={group.items} />
            </section>
        ))}
    </article>
</Layout>

<style>
    .guides-hub {
        max-width: 1080px;
        margin: 0 auto;
        padding: 4.5rem 2rem 3rem;
        color: var(--color-text-medium);
        line-height: 1.5;
    }
    .guides-hub h1 {
        font-size: 2.4rem;
        color: var(--color-text-dark);
        margin: 0 0 0.75rem;
    }
    .guides-hub .lede {
        font-size: 1.1rem;
        margin-bottom: 3rem;
        max-width: 60ch;
    }
    /* Inline prose link in the lede — a normal underlined text link, not a card. */
    .guides-hub .lede a {
        color: var(--color-text-dark);
        text-decoration: underline;
    }
    .guides-hub section {
        margin-bottom: 3rem;
    }
    .guides-hub h2 {
        font-size: 1.5rem;
        color: var(--color-text-dark);
        margin: 0 0 0.5rem;
    }
    .guides-hub h2 a {
        color: inherit;
        text-decoration: none;
    }
    .guides-hub h2 a:hover,
    .guides-hub h2 a:focus-visible {
        text-decoration: underline;
    }
    .cat-blurb {
        color: var(--color-text-light);
        margin-bottom: 1rem;
    }
</style>

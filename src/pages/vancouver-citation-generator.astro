---
import Layout from "../layouts/page.astro";
import CitationSearch from "../components/react/CitationSearch";
import {
    buildSoftwareApplication,
    buildFaqPage,
    buildBreadcrumbList,
} from "../lib/schema-org";

export const prerender = true;

const title = "Vancouver Citation Generator — Free NLM / ICMJE References";
const description =
    "Free Vancouver citation generator. Create accurate NLM / ICMJE numeric references from a URL, DOI, or ISBN — numbered list, abbreviated journals, no italics.";

const faqs = [
    {
        question: "What is the Vancouver citation style?",
        answer: "<p>Vancouver is a numeric citation-sequence system used across medicine, nursing, dentistry, public health, and most biomedical sciences. Sources are numbered in the order they first appear in your text — (1), (2), (3) — and the reference list at the end is numbered in that same order rather than alphabetized. It is maintained by the U.S. National Library of Medicine (NLM <cite>Citing Medicine</cite>) and the International Committee of Medical Journal Editors (ICMJE). This generator follows NLM <cite>Citing Medicine</cite> 2nd edition.</p>",
    },
    {
        question: "How do Vancouver in-text citations work?",
        answer: "<p>Each source is assigned a number the first time you cite it, and that number is reused every time you cite the same source again. The number sits in parentheses where an author–date style would put the author and year: \"Working memory predicts reading comprehension (1).\" Multiple sources collapse into one set of parentheses — consecutive numbers as a range, (1–3), and non-consecutive numbers separated by commas with no spaces, (1,4,7). See our <a href='/guides/in-text-citations'>in-text citations guide</a> for the full rules.</p>",
    },
    {
        question: "Why don't Vancouver references use italics?",
        answer: "<p>Vancouver descends from a print-economy tradition where italic type was reserved for emphasis and avoided in dense reference lists. As a result, the standard NLM reference italicizes nothing — not journal names, not book titles, not Latin abbreviations like <em>et al.</em> A reference list rendered with italicized journal names is a recognizable submission error. Journal names also appear in their NLM-abbreviated form, such as <code>J Cogn Dev</code> rather than <code>Journal of Cognitive Development</code>.</p>",
    },
    {
        question: "Does the Vancouver generator include DOIs?",
        answer: "<p>Yes. NLM <cite>Citing Medicine</cite> recommends including a DOI whenever one exists. The generator renders it in the compact <code>doi:10.1037/cogdev0000412</code> form — lowercase prefix, no <code>https://</code> — appended after the page range. For online-only sources without a DOI, it instead includes the full URL prefixed with <code>Available from:</code>.</p>",
    },
    {
        question: "Is this Vancouver citation generator free?",
        answer: "<p>Yes, it is completely free. Paste a URL, DOI, or ISBN, choose Vancouver, and copy a formatted reference in seconds. You can also generate citations in <a href='/'>APA, MLA, Chicago, Harvard, IEEE, and AMA</a> with the same tool, or switch styles at any time.</p>",
    },
];

const siteBase = new URL("/", Astro.site).toString();
const pageUrl = new URL("/vancouver-citation-generator/", Astro.site).toString();

const extraSchemas = [
    buildSoftwareApplication(),
    buildFaqPage(faqs),
    buildBreadcrumbList([
        { name: "Home", url: siteBase },
        { name: "Vancouver Citation Generator", url: pageUrl },
    ]),
];
---

<Layout title={title} description={description} extraSchemas={extraSchemas}>
    <section id="tool">
        <div id="text-container">
            <h1 class="heading-1">Vancouver Citation Generator</h1>
            <p class="subtitle">
                Generate accurate Vancouver (NLM / ICMJE) references in seconds.
                Paste a URL, DOI, or ISBN and get a numbered, NLM-abbreviated
                citation ready to drop into a biomedical paper — no italics, no
                guesswork.
            </p>
        </div>
        <CitationSearch includeDropdown includeManualCite defaultStyle="vancouver" client:load />
    </section>

    <article class="style-info">
        <h2>How to cite in Vancouver</h2>
        <p>
            Vancouver is a <strong>numeric citation-sequence</strong> system: the
            first source you cite becomes reference 1, the next new source
            becomes reference 2, and the reference list at the end is numbered in
            that order rather than alphabetized. In the body, the number sits in
            parentheses where an author–date style would put the author and year
            — for example, <em>“…predicts reading comprehension (1).”</em> Cite the
            same source again and you reuse its original number.
        </p>
        <p>
            Reference entries are compact. Authors are listed by surname and
            initials with no commas or periods inside the name (<code
                >Chen MS</code
            >, not <code>Chen, M. S.</code>), titles use sentence case, and
            journal names appear in their NLM-standard abbreviation (<code
                >J Cogn Dev</code
            >). The most distinctive rule is that <strong
                >nothing is italicized</strong
            > — not journal names, not book titles, not Latin abbreviations. A DOI,
            when one exists, is appended in the compact <code
                >doi:10.1037/cogdev0000412</code
            > form.
        </p>
        <p>
            This generator follows <strong
                >NLM <cite>Citing Medicine</cite> 2nd edition</strong
            >, the style most biomedical journals point to via the ICMJE
            Recommendations. For the complete rules — author thresholds for
            <em>et al.</em>, every source type, and common mistakes — read the
            <a href="/guides/vancouver">full Vancouver citation guide</a>.
        </p>
        <p>Related guides you may find useful:</p>
        <ul>
            <li>
                <a href="/guides/how-to-cite-a-journal-article"
                    >How to cite a journal article</a
                > — the most common Vancouver source type.
            </li>
            <li>
                <a href="/guides/in-text-citations">In-text citations</a> — how numeric
                citations, ranges, and reuse work in the body of your paper.
            </li>
            <li>
                <a href="/guides/ama">AMA citation guide</a> — the other major numeric
                style used in medicine, for comparison.
            </li>
        </ul>
        <p class="generic-link">
            Need a different style? Use the
            <a href="/">free citation generator</a> for APA, MLA, Chicago, Harvard,
            IEEE, and AMA.
        </p>
    </article>

    <section class="faq-section">
        <h2>Vancouver citation FAQs</h2>
        <div class="faq-container">
            {
                faqs.map((faq, i) => {
                    const open = i === 0;
                    return (
                        <details class="faq" open={open}>
                            <summary>{faq.question}</summary>
                            <div set:html={faq.answer} class="faq-content" />
                        </details>
                    );
                })
            }
        </div>
    </section>
</Layout>

<style>
    #tool {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 0 var(--page-inline-padding);
    }
    #text-container {
        text-align: center;
        margin: 4rem 0;
    }
    #text-container .heading-1 {
        margin-bottom: 1rem;
    }
    #text-container .subtitle {
        max-width: 52ch;
        margin: 0 auto;
        color: var(--color-text-light);
    }
    .style-info {
        max-width: 950px;
        margin: 0 auto;
        padding: 4rem 1.5rem 1rem;
        color: var(--color-text-medium);
        line-height: 1.6;
        overflow-wrap: break-word;
    }
    .style-info h2 {
        font-size: 1.6rem;
        margin-bottom: 1rem;
        color: var(--color-text-dark);
    }
    .style-info p {
        margin-bottom: 1rem;
    }
    .style-info ul {
        padding-left: 1.5rem;
        list-style: disc;
        margin-bottom: 1rem;
    }
    .style-info li {
        margin-bottom: 0.5rem;
    }
    .style-info a {
        color: var(--color-text-dark);
        text-decoration: underline;
    }
    .style-info code {
        font-size: 0.9em;
    }
    .style-info cite {
        font-style: italic;
    }
    .style-info .generic-link {
        font-size: 0.95rem;
        color: var(--color-text-light);
    }
    .faq-section {
        padding: 3rem var(--page-inline-padding) 4rem;
    }
    .faq-section h2 {
        text-align: center;
        font-size: 1.8rem;
        color: var(--color-text-dark);
        margin-bottom: 2rem;
    }
    .faq-container {
        display: grid;
        gap: 1rem;
        max-width: calc(950px + var(--page-inline-padding) * 2);
        margin: auto;
    }
    .faq {
        padding: 1.3rem;
        border-radius: 1rem;
        background-color: var(--color-background-3);
        text-align: left;
    }
    .faq summary {
        font-size: 1.3rem;
        cursor: pointer;
        user-select: none;
        line-height: 1.2;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
    }
    .faq[open] summary {
        margin-bottom: 1rem;
    }
    .faq[open] summary::after {
        content: url("/icons/close.svg");
        transform: translate(0, 2px);
    }
    .faq summary::after {
        content: url("/icons/open.svg");
        display: flex;
        align-items: center;
        transform: translate(-1px, 2px);
        width: 20px;
        height: 20px;
    }
    .faq-content {
        color: var(--color-text-light);
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
    .faq-content :global(a) {
        text-decoration: underline;
        color: var(--color-text-dark);
    }
    @media (max-width: 700px) {
        .faq summary {
            font-size: 1.2rem;
        }
    }
</style>
